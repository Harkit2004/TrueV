COMFYUI_BASE_URL=http://127.0.0.1:8188

# Lumina workflow JSON (default: <repo>/anime.json). Env: LUMINA_WORKFLOW_PATH only.
# On Windows use forward slashes — backslashes are mangled by .env parsing (\U, \a, etc.).
# LUMINA_WORKFLOW_PATH=C:/full/path/to/anime.json

# --- See-through (GPU worker + SSH tunnel; separate from Lumina /api/generate) ---
# Laptop / main API: forward /api/see-through/decompose to the worker via tunnel:
SEE_THROUGH_SERVICE_URL=http://127.0.0.1:9105
# SEE_THROUGH_SERVICE_SECRET=
# SEE_THROUGH_TIMEOUT_SEC=7200

# GPU droplet worker only (python run_see_through_worker.py).
# Use absolute paths that exist on the GPU machine — wrong SEE_THROUGH_PYTHON gives errno 2 / HTTP 500.
SEE_THROUGH_REPO=/path/to/see-through
SEE_THROUGH_PYTHON=/path/to/conda/envs/see_through/bin/python
# SEE_THROUGH_WORKER_PORT=9105
# SEE_THROUGH_WORKER_HOST=127.0.0.1

# --- Stretchy Studio headless Live2D export (GPU worker with Node 20+) ---
# Path to the stretchystudio folder (npm install there; requires canvas native module).
STRETCHY_STUDIO_ROOT=/root/TrueV/stretchystudio
# If `node` is not on PATH for the worker process (systemd/cron), use the full path, e.g.:
# NODE_BIN=/usr/bin/node
NODE_BIN=node
HEADLESS_EXPORT_SCRIPT=scripts/headless_live2d_export.mjs